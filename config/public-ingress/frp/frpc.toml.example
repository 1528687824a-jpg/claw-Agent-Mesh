# frpc template for the local Windows machine.
# Replace placeholders locally. Do not commit the real auth token.

serverAddr = "{{VPS_HOST}}"
serverPort = {{FRP_BIND_PORT}}

auth.method = "token"
auth.token = "{{FRP_AUTH_TOKEN}}"

transport.tls.enable = true

[[proxies]]
name = "agent-openclaw-orchestrator-api"
type = "tcp"
localIP = "127.0.0.1"
localPort = {{LOCAL_API_PORT}}
remotePort = {{FRP_REMOTE_API_PORT}}

